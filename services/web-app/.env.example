# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Optional: call a remote API from `pnpm dev` without browser CORS (same-origin to /api, Vite proxies upstream).
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_DEV_PROXY_TARGET=https://api.stage.ai-ops.tech
# VITE_USE_MOCKS=false
# VITE_ENABLE_MSW_BUNDLE=false

# Application Environment
# Options: development | staging | production
VITE_APP_ENV=development

# OAuth Configuration
VITE_OAUTH_CLIENT_ID=mr-review-web-app
