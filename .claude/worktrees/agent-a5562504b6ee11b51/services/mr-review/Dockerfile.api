############################
# Builder (deps build stage)
############################
FROM python:3.12-slim-bookworm AS builder
WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uv/bin/uv

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    libffi-dev \
    libssl-dev \
  && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock* ./
RUN /uv/bin/uv export --frozen --no-hashes | grep -v "^-e \.$" > requirements.txt

RUN --mount=type=cache,target=/root/.cache/uv \
    /uv/bin/uv pip install --system -r requirements.txt

COPY mr_review /app/mr_review
COPY api /app/api

############################
# Production runtime
############################
FROM python:3.12-slim-bookworm AS production
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
  && rm -rf /var/lib/apt/lists/*

RUN addgroup --system app && adduser --system --ingroup app \
    --no-create-home --disabled-password --shell /usr/sbin/nologin app

COPY --from=builder /usr/local /usr/local
COPY --from=builder /app /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONIOENCODING=utf-8 \
    PYTHONPATH=/app

USER app
EXPOSE 8000

CMD ["python", "-m", "uvicorn", "mr_review.main:app", "--host", "0.0.0.0", "--port", "8000"]

############################
# Test image
############################
FROM builder AS test
RUN /uv/bin/uv export --frozen --no-hashes --all-extras | grep -v "^-e \.$" > requirements-test.txt \
 && /uv/bin/uv pip install --system --no-cache -r requirements-test.txt
COPY tests /app/tests
COPY .coveragerc /app/.coveragerc
CMD ["pytest", "/app/tests", "--cov=/app/mr_review"]
