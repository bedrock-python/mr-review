# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to backend/)
DB_PATH=mr_review.db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON list of allowed origins for the frontend dev server
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
