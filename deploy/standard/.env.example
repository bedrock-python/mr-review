# mr-review — standard deployment (2 containers)
# Copy this file to .env and adjust values as needed.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d
#   open http://localhost:17242

# Port where the web UI will be available
WEB_PORT=17242

# Port where the API will be available
API_PORT=17241

# Directory on the host where application data (SQLite DB, uploads) will be stored.
# Use an absolute path for server deployments, e.g. /opt/mr-review/data
DATA_DIR=./data

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
MR_REVIEW__LOGGING__LEVEL=INFO
# Log format: true = JSON (for log aggregators), false = human-readable console output
MR_REVIEW__LOGGING__USE_JSON=true
